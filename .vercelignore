# Static HTML deploy — ignore the Next.js scaffold and backend code.
# The Next.js app remains in the repo (on the claude/review-website-files-Kek9s
# branch) but must not be served as static assets from the root.

src/
prisma/
public/
legacy-html/
node_modules/
.next/

# Backup configs (the .bak extension already stops Vercel detecting Next.js,
# but we don't want them publicly fetchable either).
package.json.bak
package-lock.json
next.config.ts.bak
postcss.config.mjs.bak
tsconfig.json.bak
eslint.config.mjs.bak
next-env.d.ts

# Env files — never ship these publicly.
.env
.env.local
.env.example

# Docs / dev artifacts not needed on the CDN.
CLAUDE.md
DEPLOYMENT.md
