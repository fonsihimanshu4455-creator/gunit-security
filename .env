# ============================================================
# Non-secret defaults committed to git.
#
# Real secrets (NEXTAUTH_SECRET, DEFAULT_ADMIN_PASSWORD, etc.) belong
# in `.env.local` for local development, and in the hosting provider's
# environment settings for production (Vercel → Project → Settings →
# Environment Variables). Values in `.env.local` and Vercel env vars
# override what is set here.
#
# See .env.example for the full list of variables the app expects.
# ============================================================

# Prisma — SQLite database file, relative to the schema at prisma/schema.prisma
DATABASE_URL="file:./dev.db"
